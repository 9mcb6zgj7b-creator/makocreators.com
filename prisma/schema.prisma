generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions          Session[]
  memberships       WorkspaceMember[]
  creatorPersonas   CreatorPersona[]
  creatorLeads      CreatorLead[]
  creatorMatchRuns  CreatorMatchRun[]
  shortlists        Shortlist[]
  outreachDrafts    OutreachDraft[]
  dashboardTasks    DashboardTask[]
  approvalsCreated  Approval[] @relation("ApprovalCreatedBy")
  approvalsReviewed Approval[] @relation("ApprovalReviewedBy")
  conversationThreadsAssigned ConversationThread[] @relation("ConversationThreadAssignedHuman")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LoginChallenge {
  id          String   @id @default(cuid())
  identifier  String
  email       String?
  phone       String?
  codeHash    String
  failedAttempts Int    @default(0)
  lockedAt    DateTime?
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([identifier])
  @@index([expiresAt])
}

model AuthRateLimit {
  id        String   @id @default(cuid())
  action    String
  key       String
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([action, key])
  @@index([resetAt])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          WorkspaceMember[]
  creatorPersonas  CreatorPersona[]
  creatorLeads     CreatorLead[]
  creatorMatchRuns CreatorMatchRun[]
  shortlists       Shortlist[]
  outreachDrafts   OutreachDraft[]
  campaigns        Campaign[]
  dashboardTasks   DashboardTask[]
  approvals        Approval[]
  conversationThreads ConversationThread[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(OWNER)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model CreatorPersona {
  id          String        @id @default(cuid())
  workspaceId String
  createdById String
  title       String
  description String        @db.Text
  business    String        @db.Text
  referenceUrls String[]
  competitorUrls String[]
  idealCreator String?      @db.Text
  status      PersonaStatus @default(DRAFT)
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  matchRuns CreatorMatchRun[]
  shortlistItems ShortlistItem[]

  @@index([workspaceId, createdAt])
}

enum PersonaStatus {
  DRAFT
  GENERATED
  ARCHIVED
}

model CreatorLead {
  id          String            @id @default(cuid())
  directoryEntryId String?
  workspaceId String
  createdById String
  source      CreatorLeadSource
  status      CreatorLeadStatus @default(PENDING_ANALYSIS)
  platform    Platform         @default(OTHER)
  profileUrl  String
  displayName String?
  handle      String?
  city        String?
  categories  String[]
  followers   Int?
  avgViews    Int?
  contactEmail String?
  contactPhone String?
  contactNotes String?         @db.Text
  priceMin    Int?
  priceMax    Int?
  notes       String?          @db.Text
  rawInput    Json             @default("{}")
  metadata    Json             @default("{}")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  directoryEntry CreatorDirectoryEntry? @relation(fields: [directoryEntryId], references: [id], onDelete: SetNull)
  conversationThreads ConversationThread[]

  @@unique([workspaceId, profileUrl])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, platform])
  @@index([directoryEntryId])
}

enum CreatorLeadSource {
  LINK
  EXCEL
  MANUAL
}

enum CreatorLeadStatus {
  PENDING_ANALYSIS
  ANALYZED
  NEEDS_REVIEW
  APPROVED
  ARCHIVED
  FAILED
}

model CreatorDirectoryEntry {
  id              String   @id @default(cuid())
  primaryName     String?
  normalizedName  String?
  primaryEmail    String?
  normalizedEmail String?  @unique
  profileUrls     String[]
  platforms       Platform[]
  categories      String[]
  contactNotes    String?  @db.Text
  sourceCount     Int      @default(0)
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  leads CreatorLead[]

  @@index([normalizedName])
  @@index([lastSeenAt])
}

model Creator {
  id          String   @id @default(cuid())
  displayName String
  handle      String   @unique
  bio         String?  @db.Text
  avatarUrl   String?
  location    String?
  categories  String[]
  languages   String[]
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profiles       CreatorSocialProfile[]
  matchResults   CreatorMatchResult[]
  shortlistItems ShortlistItem[]
  approvals      Approval[]

}

model CreatorSocialProfile {
  id          String   @id @default(cuid())
  creatorId   String
  platform    Platform
  url         String
  handle      String
  followers   Int?
  avgViews    Int?
  engagementRate Float?
  verified    Boolean @default(false)
  metadata    Json    @default("{}")
  updatedAt   DateTime @updatedAt

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([platform, handle])
  @@index([creatorId])
}

enum Platform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
  XIAOHONGSHU
  OTHER
}

model CreatorMatchRun {
  id          String         @id @default(cuid())
  workspaceId String
  createdById String
  personaId   String?
  status      MatchRunStatus @default(PENDING)
  query       Json           @default("{}")
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  persona   CreatorPersona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  results   CreatorMatchResult[]

  @@index([workspaceId, createdAt])
}

enum MatchRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model CreatorMatchResult {
  id        String @id @default(cuid())
  runId     String
  creatorId String
  score     Float
  reasons   String[]
  risks     String[]
  estimatedPriceMin Int?
  estimatedPriceMax Int?
  metadata  Json   @default("{}")
  createdAt DateTime @default(now())

  run     CreatorMatchRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  creator Creator         @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([runId, creatorId])
  @@index([creatorId])
}

model Shortlist {
  id          String   @id @default(cuid())
  workspaceId String
  createdById String
  name        String
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  items     ShortlistItem[]

  @@index([workspaceId, createdAt])
}

model ShortlistItem {
  id          String   @id @default(cuid())
  shortlistId String
  creatorId   String
  personaId   String?
  priority    Int      @default(0)
  status      ShortlistItemStatus @default(NEW)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shortlist Shortlist       @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  creator   Creator         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  persona   CreatorPersona? @relation(fields: [personaId], references: [id], onDelete: SetNull)

  @@unique([shortlistId, creatorId])
}

enum ShortlistItemStatus {
  NEW
  CONTACTED
  REPLIED
  APPROVED
  REJECTED
}

model OutreachDraft {
  id          String   @id @default(cuid())
  workspaceId String
  createdById String
  shortlistItemId String?
  channel     OutreachChannel
  subject     String?
  body        String   @db.Text
  status      OutreachStatus @default(DRAFT)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  approvals Approval[]
  conversationThreads ConversationThread[]

  @@index([workspaceId, createdAt])
}

enum OutreachChannel {
  EMAIL
  DM
  SMS
  WHATSAPP
  WECHAT
  OTHER
}

enum OutreachStatus {
  DRAFT
  SENT
  ARCHIVED
}

model ConversationThread {
  id              String                  @id @default(cuid())
  workspaceId     String
  creatorLeadId   String?
  outreachDraftId String?
  assignedHumanId String?
  state           ConversationThreadState @default(DRAFT)
  subject         String?
  creatorEmail    String?
  replyToEmail    String?
  lastIntent      String?
  lastConfidence  Float?
  nextActionAt    DateTime?
  lastMessageAt   DateTime?
  metadata        Json                    @default("{}")
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creatorLead     CreatorLead?   @relation(fields: [creatorLeadId], references: [id], onDelete: SetNull)
  outreachDraft   OutreachDraft? @relation(fields: [outreachDraftId], references: [id], onDelete: SetNull)
  assignedHuman   User?          @relation("ConversationThreadAssignedHuman", fields: [assignedHumanId], references: [id], onDelete: SetNull)
  messages        ConversationMessage[]

  @@index([workspaceId, state, nextActionAt])
  @@index([creatorLeadId])
  @@index([assignedHumanId])
  @@index([replyToEmail])
}

model ConversationMessage {
  id                String                       @id @default(cuid())
  threadId          String
  direction         ConversationMessageDirection
  provider          String?
  providerMessageId String?
  fromEmail         String?
  toEmail           String?
  subject           String?
  textBody          String?                      @db.Text
  htmlBody          String?                      @db.Text
  intent            String?
  confidence        Float?
  extractedTimes    Json                         @default("[]")
  metadata          Json                         @default("{}")
  createdAt         DateTime                     @default(now())

  thread            ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([providerMessageId])
}

enum ConversationThreadState {
  DRAFT
  READY_TO_SEND
  INITIAL_SENT
  REPLIED
  INTERESTED_ASSETS
  WAITING_ASSET_APPROVAL
  ASSETS_SENT
  INTERESTED_VISIT
  WAITING_VISIT_APPROVAL
  VISIT_SCHEDULED
  FOLLOW_UP_DUE
  NO_RESPONSE
  REJECTED
  NEEDS_HUMAN
  CLOSED
}

enum ConversationMessageDirection {
  OUTBOUND
  INBOUND
  INTERNAL
}

model Campaign {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  objective   String?
  budgetMin   Int?
  budgetMax   Int?
  startsAt    DateTime?
  endsAt      DateTime?
  status      CampaignStatus @default(DRAFT)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     DashboardTask[]
  approvals Approval[]

  @@index([workspaceId, createdAt])
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model DashboardTask {
  id          String              @id @default(cuid())
  workspaceId String
  createdById String
  campaignId  String?
  title       String
  description String?             @db.Text
  type        DashboardTaskType   @default(GENERAL)
  status      DashboardTaskStatus @default(OPEN)
  priority    Int                 @default(0)
  dueAt       DateTime?
  metadata    Json                @default("{}")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, priority, createdAt])
  @@index([campaignId])
}

enum DashboardTaskType {
  GENERAL
  CREATOR_REVIEW
  CAMPAIGN_SETUP
  OUTREACH
  REPORT
}

enum DashboardTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  ARCHIVED
}

model Approval {
  id              String         @id @default(cuid())
  workspaceId     String
  createdById     String
  reviewedById    String?
  campaignId      String?
  creatorId       String?
  outreachDraftId String?
  type            ApprovalType
  title           String
  summary         String         @db.Text
  riskLevel       ApprovalRisk
  status          ApprovalStatus @default(PENDING)
  decisionNotes   String?        @db.Text
  reviewedAt      DateTime?
  metadata        Json           @default("{}")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("ApprovalCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  reviewedBy    User?          @relation("ApprovalReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  campaign      Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  creator       Creator?       @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  outreachDraft OutreachDraft? @relation(fields: [outreachDraftId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, riskLevel, createdAt])
  @@index([campaignId])
  @@index([creatorId])
  @@index([outreachDraftId])
}

enum ApprovalType {
  SEND_OUTREACH
  SEND_ASSETS
  SCHEDULE_VISIT
  SHIP_SAMPLE
  PAID_COLLABORATION
  USAGE_RIGHTS
  APPROVE_AI_SCRIPT
  GENERAL_REVIEW
}

enum ApprovalRisk {
  LOW
  MEDIUM
  HIGH
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CHANGES
  ARCHIVED
}
