# App
NEXT_PUBLIC_SITE_URL=https://makocreators.com
NEXT_PUBLIC_APP_NAME="Mako Creator"

# Auth
# Required in production. Generate with: openssl rand -base64 32
AUTH_SECRET=
# Local development only; ignored in production.
AUTH_SHOW_DEV_CODE=false

# Database
DATABASE_URL=

# Email/SMS providers
RESEND_API_KEY=
RESEND_FROM_EMAIL=Mako Creator <login@makocreators.com>
RESEND_WEBHOOK_SECRET=
INBOUND_EMAIL_DOMAIN=inbound.makocreators.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# AI / creator matching
OPENAI_API_KEY=
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# Automation
CRON_SECRET=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
